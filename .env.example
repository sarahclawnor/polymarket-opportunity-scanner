# API Keys

# --- Research Providers (at least one required) ---

# Option 1: Direct Perplexity API
# Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_key_here

# Option 2: Perplexity via OpenRouter (if you don't have direct Perplexity API)
# Set OPENROUTER_API_KEY and optionally PERPLEXITY_MODEL
OPENROUTER_API_KEY=your_openrouter_key
# PERPLEXITY_MODEL=sonar-pro  # Options: sonar, sonar-pro, sonar-reasoning, sonar-deep-research

# Option 3: AskNews
# Get from https://docs.asknews.app/
ASKNEWS_CLIENT_ID=your_asknews_client_id
ASKNEWS_SECRET=your_asknews_secret

# --- LLM for Forecasting ---

# OpenAI (default)
OPENAI_API_KEY=your_openai_key

# Or use OpenRouter for forecasting too
# OPENROUTER_API_KEY=already_set_above

# --- Optional: Notifications ---

# Telegram alerts
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Discord alerts
# DISCORD_WEBHOOK_URL=your_webhook_url
